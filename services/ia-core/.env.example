# =============================================================================
# NeoBotSeller IA Core — variables de entorno
# Copia a .env y ajusta según tu entorno
# =============================================================================

# --- Servicio ---
IA_CORE_HOST=0.0.0.0
IA_CORE_PORT=8090

# --- Proveedor LLM: openai | ollama ---
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# --- OpenAI (cuando LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama (cuando LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
# Remoto en red local (3080 / 32GB): descomenta y usa qwen2.5:7b-instruct
# OLLAMA_BASE_URL=http://192.168.1.50:11434
# LLM_MODEL=qwen2.5:7b-instruct

# --- Prompt del asistente ---
SYSTEM_PROMPT=Eres NeoBotSeller, un asistente de ventas amable y conciso. Respondes en el idioma del usuario.

# --- Conversation service (Redis/) ---
CONVERSATION_SERVICE_URL=http://localhost:8093
CONVERSATION_SERVICE_ENABLED=true
# Solo fallback en memoria si el servicio no responde
CONVERSATION_MAX_TURNS=20
CONVERSATION_TTL_SECONDS=300
MAX_TOOL_ROUNDS=5

# --- Odoo MCP (stock + CRM) ---
ODOO_MCP_ENABLED=true
ODOO_URL=http://localhost:8069
ODOO_DB_NAME=neobotseller
ODOO_LOGIN=admin
ODOO_USER_PASSWORD=admin

# Hub MCP unificado (Odoo + RAG tools)
ACTIONS_SERVICE_URL=http://localhost:8092
