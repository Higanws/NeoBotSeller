EMBEDDING_SERVICE_HOST=0.0.0.0
EMBEDDING_SERVICE_PORT=8094

# Carpeta con PDFs a indexar (relativa a RAG/)
DOCUMENTS_DIR=../documents

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=neobotseller

# Embeddings locales (fastembed) — sin API key
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Vigilar carpeta y re-indexar al detectar PDFs nuevos
EMBEDDING_WATCH=false
EMBEDDING_WATCH_INTERVAL_SECONDS=30

# OpenAI (opcional: EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
